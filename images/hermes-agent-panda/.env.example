# Local-run env for the hermes-agent-panda image. Copy to .env (gitignored).
# In-cluster these come from the panda-chat chart Secret / vals, not this file.

# Model key (name must match the chart's llm.apiKeyEnv)
ANTHROPIC_API_KEY=

# Langfuse tracing (Hermes observability/langfuse plugin).
# HERMES_-prefixed names win; standard LANGFUSE_* are also accepted.
HERMES_LANGFUSE_PUBLIC_KEY=pk-lf-...
HERMES_LANGFUSE_SECRET_KEY=sk-lf-...
HERMES_LANGFUSE_BASE_URL=https://langfuse.analytics.production.platform.ethpandaops.io
# Tag traces per devnet so the Langfuse UI can filter by environment.
HERMES_LANGFUSE_ENV=bal-devnet-7

# Devnet context (set by the chart in-cluster)
DEVNET_NETWORK=bal-devnet-7
